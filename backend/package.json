{
  "name": "tiny-link",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start:api": "node dist/main.api.js",
    "start:worker": "node dist/main.worker.js",
    "start:api:dev": "nest start --watch --entryFile main.api",
    "start:worker:dev": "nest start --watch --entryFile main.worker",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings 0",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "test": "jest --config jest.config.ts --selectProjects unit",
    "test:integration": "jest --config jest.config.ts --selectProjects integration --runInBand",
    "test:e2e": "jest --config jest.config.ts --selectProjects e2e --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^5.20.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.13.0",
    "ioredis": "^5.4.1",
    "nanoid": "^3.3.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ua-parser-js": "^1.0.39",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.13.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
